# PostgreSQL
DATABASE_URL=postgres://user:pass@host:5432/salestwo
DB_SSL=false

# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173

# JWT
JWT_SECRET=change-me

# Google Calendar — OAuth client credentials (Phase 1.3)
# Configured in Google Cloud Console > APIs & Services > Credentials.
# The redirect URI MUST be registered there exactly as below.
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=
# Public-facing callback URL. Examples:
#   - dev:  https://<replit-domain>/api/functions/google-calendar/callback
#   - prod: https://app.salestwocrm.com.br/api/functions/google-calendar/callback
GCAL_REDIRECT_URI=

# Google Calendar token encryption (Phase 1.1)
# 32-byte key, base64-encoded. Generate with:
#   openssl rand -base64 32
# WARNING: losing this key makes existing tokens unrecoverable;
# affected vendors will have to reconnect their Google account.
GCAL_TOKEN_ENC_KEY=
