modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend Dev Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API Server"

[[workflows.workflow]]
name = "Frontend Dev Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm start"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3002

[deployment]
deploymentTarget = "vm"
build = ["bash", "-c", "npm run build && cd backend && npm install"]
run = ["bash", "-c", "cd backend && PORT=5000 npm start"]

[userenv]

[userenv.shared]
JWT_SECRET = "wescctech-crm-jwt-secret-change-in-production-2024"
BACKEND_PORT = "3001"
SMTP_HOST = "email-ssl.com.br"
SMTP_PORT = "465"
COMMISSION_REPORT_RECIPIENTS = "tais.dequi@wescctech.com.br"

[userenv.development]
GCAL_TOKEN_ENC_KEY = "CsdPtPQ6j3mSeAMyADo/FW5FdPzgsht+yoHE8zUVLc4="
GCAL_REDIRECT_URI = "https://c3924b13-7d9b-4c71-91ee-80c0159c6078-00-173j3vp3rbr6l.spock.replit.dev/api/functions/google-calendar/callback"

